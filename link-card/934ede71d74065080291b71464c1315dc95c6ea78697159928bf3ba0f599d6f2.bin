。\"},\"toast\":{\"save\":{\"error\":\"保存に失敗しました\",\"loading\":\"保存中...\",\"success\":\"保存しました\"},\"delete\":{\"error\":\"削除に失敗しました\",\"loading\":\"削除中...\",\"success\":\"削除しました\"}}},\"UserSetting\":{\"title\":\"設定\",\"description\":\"アカウント設定を管理します。\",\"avatar\":{\"title\":\"アバター画像\",\"description\":\"ログイン中のアバター画像URLを設定できます。\",\"label\":\"アバター画像URL\",\"placeholder\":\"https://api.dicebear.com/9.x/notionists-neutral/svg?seed=silverbirder\",\"action\":\"更新する\",\"toast\":{\"error\":\"更新に失敗しました\",\"loading\":\"更新中...\",\"success\":\"更新しました\"}},\"theme\":{\"title\":\"テーマカラー\",\"description\":\"画面のテーマカラーを 0〜360 の範囲で調整できます。\",\"label\":\"Hue（0〜360）\",\"presets\":\"プリセット\",\"placeholder\":\"238\",\"action\":\"適用する\",\"resetAction\":\"リセットする\",\"toast\":{\"error\":\"更新に失敗しました\",\"loading\":\"更新中...\",\"success\":\"更新しました\"},\"resetToast\":{\"error\":\"リセットに失敗しました\",\"loading\":\"リセット中...\",\"success\":\"リセットしました\"}},\"webhook\":{\"title\":\"Webhook通知\",\"description\":\"Slack Incoming Webhook URL を登録すると通知を受け取れます。\",\"label\":\"Webhook URL\",\"placeholder\":\"https://hooks.slack.com/services/...\",\"action\":\"保存する\",\"watchRequiredToast\":\"ウォッチするにはWebhook URLの登録が必要です。先に設定してください。\",\"toast\":{\"error\":\"Webhookの更新に失敗しました\",\"loading\":\"Webhookを更新中...\",\"success\":\"Webhookを更新しました\"}},\"withdraw\":{\"title\":\"退会\",\"description\":\"退会すると、以下のデータが削除されます。削除されたデータは復元できません。\",\"items\":{\"featureRequests\":\"・投稿したリクエスト\",\"reactions\":\"・リクエストに付けたリアクション\"},\"action\":\"退会する\",\"dialog\":{\"title\":\"退会しますか？\",\"description\":\"投稿したリクエストとリアクションが削除されます。\",\"cancel\":\"キャンセル\"},\"toast\":{\"error\":\"退会に失敗しました\",\"loading\":\"退会処理中...\",\"success\":\"退会しました\"}}},\"AdminApp\":{\"settingLinkLabel\":\"設定\",\"notFoundTitle\":\"404 - Not Found\",\"notFoundDescription\":\"お探しのページは見つかりませんでした。\"},\"AdminDashboard\":{\"toast\":{\"create\":{\"error\":\"作成に失敗しました\",\"loading\":\"作成中...\",\"success\":\"プロダクトを作成しました\"}},\"dialog\":{\"title\":\"新しいプロダクトを作成\",\"description\":\"名前を入力して作成すると、そのプロダクトの管理ページに移動します。\",\"nameLabel\":\"プロダクト名\",\"nameAriaLabel\":\"プロダクト名\",\"namePlaceholder\":\"例: Fequest\",\"nameHelper\":\"名前は後から変更できます。\"},\"buttons\":{\"cancel\":\"キャンセル\",\"create\":\"作成する\",\"createProduct\":\"プロダクトを作成\"},\"empty\":{\"title\":\"プロダクトが未登録のようです...。\",\"description\":\"新しいプロダクトを作成して、リクエストを集めましょう！\"},\"list\":{\"title\":\"プロダクト一覧\",\"description\":\"あなたが登録したプロダクトの一覧です。\",\"cta\":\"新しいプロダクトを作成して、リクエストを集めましょう。\"}},\"AdminProduct\":{\"status\":{\"open\":{\"actionLabel\":\"完了にする\",\"toast\":{\"error\":\"完了への変更に失敗しました\",\"loading\":\"完了にしています\",\"success\":\"完了にしました\"}},\"closed\":{\"actionLabel\":\"未完了に戻す\",\"toast\":{\"error\":\"未完了に戻すことに失敗しました\",\"loading\":\"未完了に戻しています\",\"success\":\"未完了に戻しました\"}}},\"toast\":{\"updateName\":{\"error\":\"名前の保存に失敗しました\",\"loading\":\"名前を保存中...\",\"success\":\"名前を保存しました\"},\"updateDetails\":{\"error\":\"表示情報の保存に失敗しました\",\"loading\":\"表示情報を保存中...\",\"success\":\"表示情報を保存しました\"},\"deleteProduct\":{\"error\":\"プロダクトの削除に失敗しました\",\"loading\":\"プロダクトを削除中...\",\"success\":\"プロダクトを削除しました\"},\"deleteRequest\":{\"error\":\"リクエストの削除に失敗しました\",\"loading\":\"リクエストを削除中...\",\"success\":\"リクエストを削除しました\"},\"updateComment\":{\"error\":\"管理者コメントの保存に失敗しました\",\"loading\":\"管理者コメントを保存中...\",\"success\":\"管理者コメントを保存しました\"},\"updateStatus\":{\"loading\":\"更新中...\"}},\"header\":{\"title\":\"プロダクトの管理\",\"userPageLabel\":\"ユーザー向けページ\",\"userPageAriaLabel\":\"ユーザー側のプロダクトページ {url}\",\"description\":\"プロダクト情報の更新と、リクエストのステータス管理を行えます。\"},\"rename\":{\"label\":\"プロダクト名\",\"ariaLabel\":\"プロダクト名\",\"save\":\"名前を保存する\"},\"details\":{\"title\":\"プロダクトの補足情報\",\"description\":\"ロゴや説明文を設定して、ユーザーにわかりやすく伝えましょう。\",\"logoLabel\":\"ロゴURL (任意)\",\"logoAriaLabel\":\"プロダクトロゴURL\",\"logoHelper\":\"画像のURLを入力すると、ユーザーにプロダクトのロゴが表示されます。\",\"homePageLabel\":\"ホームページURL (任意)\",\"homePageAriaLabel\":\"プロダクトホームページURL\",\"homePageHelper\":\"プロダクトの公式サイトやLPへのリンクを登録できます。\",\"descriptionLabel\":\"プロダクト説明文 (任意)\",\"descriptionAriaLabel\":\"プロダクト説明文\",\"descriptionPlaceholder\":\"サー